# Backend origin
OMATRUST_BACKEND_URL=http://localhost:3000
OMATRUST_DEBUG=false

# Session + SIWE
OMATRUST_SESSION_SECRET=replace-with-a-long-random-secret
OMATRUST_SESSION_TTL_HOURS=24
OMATRUST_SIWE_NONCE_TTL_MINUTES=10
OMATRUST_ALLOWED_SIWE_DOMAINS=reputation.omatrust.org,registry.omatrust.org,localhost:3000
OMATRUST_BROWSER_CLIENT_ID=omatrust-browser

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace-with-service-role-key

# Stripe
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me
STRIPE_PAID_PRICE_ID=price_replace_me

# Optional Thirdweb managed/server wallet for delegated EAS submission
THIRDWEB_SECRET_KEY=
THIRDWEB_SERVER_WALLET_ADDRESS=
# Private-key fallback for delegated EAS submission
EAS_DELEGATE_PRIVATE_KEY=

# Relay / chain
OMATRUST_ACTIVE_CHAIN=omachain-testnet
# Premium RPC is the entitlement-limited endpoint used for paid-quality reads and managed backend flows.
OMATRUST_PREMIUM_RPC_URL=https://rpc.testnet.chain.oma3.org/
# Safety cap for proxied eth_getLogs block span on the premium endpoint.
OMATRUST_PREMIUM_RPC_MAX_LOG_RANGE=50000
OMATRUST_MAX_GAS_PER_TX=800000

# Sponsor policy
OMATRUST_FREE_ANNUAL_SPONSORED_WRITES=10
# Premium reads are counted only against the premium RPC path, not the public rate-limited path.
OMATRUST_FREE_ANNUAL_PREMIUM_READS=100
OMATRUST_PAID_ANNUAL_SPONSORED_WRITES=1000
OMATRUST_PAID_ANNUAL_PREMIUM_READS=100000
# Must include at least the free-tier onboarding schema UID(s) or sponsored onboarding writes will fail.
OMATRUST_FREE_ALLOWED_SCHEMA_UIDS=0xreplace_with_free_onboarding_schema_uid
OMATRUST_PAID_ALLOWED_SCHEMA_UIDS=*
