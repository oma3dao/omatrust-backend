# Backend origin
OMATRUST_BACKEND_URL=http://localhost:3000

# Session + SIWE
OMATRUST_SESSION_SECRET=replace-with-a-long-random-secret
OMATRUST_SESSION_TTL_HOURS=24
OMATRUST_SIWE_NONCE_TTL_MINUTES=10
OMATRUST_ALLOWED_SIWE_DOMAINS=reputation.omatrust.org,registry.omatrust.org,localhost:3000
OMATRUST_BROWSER_CLIENT_ID=omatrust-browser

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace-with-service-role-key

# Stripe
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me
STRIPE_PAID_PRICE_ID=price_replace_me

# Relay / chain
OMACHAIN_CHAIN_ID=66238
OMACHAIN_CHAIN_NAME=OMAchain Testnet
OMACHAIN_RPC_URL=https://rpc.testnet.chain.oma3.org/
OMACHAIN_EAS_ADDRESS=0x8835AF90f1537777F52E482C8630cE4e947eCa32
OMATRUST_RELAY_PRIVATE_KEY=0xreplace-with-relay-private-key
OMATRUST_MAX_GAS_PER_TX=800000

# Sponsor policy
OMATRUST_FREE_MONTHLY_SPONSORED_WRITES=1
OMATRUST_FREE_MONTHLY_API_READS=100
OMATRUST_PAID_MONTHLY_SPONSORED_WRITES=100
OMATRUST_PAID_MONTHLY_API_READS=10000
OMATRUST_FREE_ALLOWED_SCHEMA_UIDS=
OMATRUST_PAID_ALLOWED_SCHEMA_UIDS=*
